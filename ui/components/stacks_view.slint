import { ScrollView } from "std-widgets.slint";
import { Stack } from "../types.slint";
import { CommitCard } from "commit_card.slint";

export component StacksView inherits Rectangle {
    in property <[Stack]> stacks;
    callback commit-selected(string);
    callback abandon-requested(string);
    callback commit-dropped-onto(string, string);
    callback commit-dropped-between(string, string);  // (dragged-id, before-id)
    background: #1a1a2e;

    ScrollView {
        HorizontalLayout {
            padding: 12px;
            spacing: 12px;

            for stack in root.stacks: Rectangle {
                width: 280px;
                background: #1e2a3a;
                border-radius: 8px;

                VerticalLayout {
                    padding: 10px;
                    spacing: 0px;

                    Text {
                        text: stack.name;
                        color: #c0c8d0;
                        font-size: 14px;
                        font-weight: 700;
                    }

                    // Drop zone above the first commit ("before-id" = "" means top of stack)
                    top-drop-rect := Rectangle {
                        height: 8px;
                        border-radius: 3px;
                        background: top-slot.contains-drag ? #4fc3f7.transparentize(40%) : transparent;
                        animate background { duration: 120ms; }
                        top-slot := DropArea {
                            can-drop(event) => { event.mime-type == "text/plain" }
                            dropped(event) => { root.commit-dropped-between(event.data, ""); }
                        }
                    }

                    for commit in stack.commits: VerticalLayout {
                        spacing: 0px;

                        CommitCard {
                            commit: commit;
                            clicked(id)           => { root.commit-selected(id); }
                            abandon-requested(id) => { root.abandon-requested(id); }
                            drop-onto(dragged, target) => { root.commit-dropped-onto(dragged, target); }
                        }

                        // Drop zone below this commit (before-id = this commit's id)
                        slot-rect := Rectangle {
                            height: 8px;
                            border-radius: 3px;
                            background: slot-drop.contains-drag ? #4fc3f7.transparentize(40%) : transparent;
                            animate background { duration: 120ms; }
                            slot-drop := DropArea {
                                can-drop(event) => { event.mime-type == "text/plain" }
                                dropped(event) => { root.commit-dropped-between(event.data, commit.commit-id); }
                            }
                        }
                    }
                }
            }
        }
    }
}
