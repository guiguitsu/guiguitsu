import { DiffViewer } from "diff_viewer.slint";
import { DiffLine } from "../types.slint";

export component DetailPanel inherits Rectangle {
    in property <[DiffLine]> diff-lines;
    background: #2a3d3d;

    DiffViewer {
        width: parent.width;
        height: parent.height;
        lines: root.diff-lines;
    }
}
