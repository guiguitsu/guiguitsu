import { StackCommit } from "../types.slint";

export component CommitCard inherits Rectangle {
    in property <StackCommit> commit;
    callback clicked(string);
    callback abandon-requested(string);

    height: 90px;
    background: root.commit.is-conflicted ? #4a2b2b : #2b3a4a;
    border-radius: 6px;

    popup := PopupWindow {
        x: 0px;
        y: root.height;
        width: 160px;
        height: 76px;

        Rectangle {
            background: #1e2a3a;
            border-radius: 4px;
            drop-shadow-blur: 8px;
            drop-shadow-color: #00000088;

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                diff-area := TouchArea {
                    height: 38px;
                    Rectangle {
                        background: diff-area.has-hover ? #2b3d50 : transparent;
                        border-radius: 4px;
                        Text { x: 12px; y: (parent.height - self.height) / 2; text: "View Diff"; color: #e0e8f0; font-size: 13px; }
                    }
                    clicked => { root.clicked(root.commit.commit-id); }
                }

                abandon-area := TouchArea {
                    height: 38px;
                    Rectangle {
                        background: abandon-area.has-hover ? #3d2020 : transparent;
                        border-radius: 4px;
                        Text { x: 12px; y: (parent.height - self.height) / 2; text: "Abandon"; color: #ff6b6b; font-size: 13px; }
                    }
                    clicked => { root.abandon-requested(root.commit.commit-id); }
                }
            }
        }
    }

    TouchArea {
        clicked => { root.clicked(root.commit.commit-id); }
        pointer-event(event) => {
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.up) {
                popup.show();
            }
        }
    }

    VerticalLayout {
        padding: 10px;
        spacing: 4px;

        Text {
            text: root.commit.description;
            color: #e0e8f0;
            font-size: 13px;
            overflow: elide;
        }

        Text {
            text: root.commit.change-id;
            color: #b388ff;
            font-size: 11px;
            font-family: "monospace";
        }

        HorizontalLayout {
            spacing: 8px;

            Text {
                text: root.commit.author;
                color: #8899aa;
                font-size: 11px;
            }

            Text {
                text: root.commit.timestamp;
                color: #667788;
                font-size: 11px;
            }
        }
    }
}
